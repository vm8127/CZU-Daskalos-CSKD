<methods>
<class-id>Pokus</class-id> <category>other methods</category>

<body package="DaskalosUserClasses" selector="pohlavi">pohlavi
	rodneCislo isNil ifTrue: [^'nezname'].
	"(rodneCislo at: 3) = $5 | ((rodneCislo at: 3) = $6) 
		ifTrue: [^'zena']
		ifFalse: [^'muz']"
	(#($5 $6) includes: (rodneCislo at: 3)) ifTrue: [^'zena'] ifFalse: [^'muz']</body>

<body package="DaskalosUserClasses" selector="vek">vek
	datumNarozeni isNil ifTrue: [^-1].
	^((Date today subtractDate: datumNarozeni) / 365.2422) truncated</body>
