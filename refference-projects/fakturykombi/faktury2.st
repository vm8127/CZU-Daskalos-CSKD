"generated by Daskalos"

     cislo := (self checkValue: anObject forVariable: #cislo)</body>

<body package="DaskalosUserClasses" selector="polozky">polozky
"generated by Daskalos"

     ^polozky</body>
</methods>

<methods>
<class-id>Faktura</class-id> <category>instance initialization</category>

<body package="DaskalosUserClasses" selector="initialize">initialize
"generated by Daskalos"

     super initialize.
