     name := nil.
     publicationYear := nil.
     genre := nil.
     author := nil.
</body>
</methods>

<methods>
<class-id>Book</class-id> <category>other methods</category>

<body package="DaskalosUserClasses" selector="age">age
	^Date today year - publicationYear</body>

<body package="DaskalosUserClasses" selector="averageRating">averageRating
	| ratings |
	ratings := Rating allInstances select: [:r | r book = self].
	ratings isEmpty ifTrue: [^0].
	^(ratings collect: [:r | r value]) avg asFloat</body>

<body package="DaskalosUserClasses" selector="numberOfRatings">numberOfRatings
	| ratings |
	ratings := Rating allInstances select: [:r | r book = self].
	ratings isEmpty ifTrue: [^0].
	^ratings size</body>
</methods>


